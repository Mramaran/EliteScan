# EliteMed - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ========== Google Gemini AI API ==========
GEMINI_API_KEY=your_gemini_api_key_here

# ========== Firebase Configuration ==========
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase Android
FIREBASE_ANDROID_API_KEY=your_android_api_key
FIREBASE_ANDROID_APP_ID=your_android_app_id

# Firebase iOS
FIREBASE_IOS_API_KEY=your_ios_api_key
FIREBASE_IOS_APP_ID=your_ios_app_id
FIREBASE_IOS_BUNDLE_ID=com.example.localtest

# Firebase Web
FIREBASE_WEB_API_KEY=your_web_api_key
FIREBASE_WEB_APP_ID=your_web_app_id
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# ========== Instructions ==========
# 1. Get Gemini API Key: https://makersuite.google.com/app/apikey
# 2. Get Firebase Config: https://console.firebase.google.com
# 3. Copy this file to .env
# 4. Replace all placeholder values with actual keys
# 5. Never commit .env to version control!
